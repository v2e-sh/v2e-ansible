# macOS
.DS_Store

# Ansible runtime artifacts
*.retry
fact_cache/
__pycache__/

# Galaxy deps installed locally / by CI+cloud-init — declared in requirements.yml, never committed
.galaxy/
.ansible/

# Vault password files and secrets — never commit
.vault_pass
vault-password*
*.vault

# Local inventory overrides that may hold real hosts/creds
inventory/*.local.ini
