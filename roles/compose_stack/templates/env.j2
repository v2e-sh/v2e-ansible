# Managed by Ansible (compose_stack role). Non-secret config + SOPS secrets.
# Consumed by docker compose via env_files (../.env from each stack dir).
DOMAIN={{ compose_stack_domain }}
INTERNAL_DOMAIN={{ compose_stack_internal_domain | default("int." + compose_stack_domain) }}
ACME_EMAIL={{ compose_stack_acme_email }}
CERT_RESOLVER={{ compose_stack_cert_resolver }}
{# docker compose INTERPOLATES `$` inside env-file values (a literal `$2a$10$...` bcrypt
   hash becomes "$2a" + "$10" + an empty unset-variable expansion — silently breaking
   TinyAuth logins). Escape every secret as `$$` so compose restores the literal `$`. #}
CF_DNS_API_TOKEN={{ cf_dns_api_token | default('') | replace('$', '$$') }}
TINYAUTH_AUTH_USERS={{ tinyauth_auth_users | default('') | replace('$', '$$') }}
{# COMPOSE-3 secrets — default('') keeps rendering working when the semaphore/arcane
   stacks aren't enabled; each stack's compose guards with ${VAR:?} at deploy time. #}
SEMAPHORE_DB_PASS={{ semaphore_db_pass | default('') | replace('$', '$$') }}
SEMAPHORE_ADMIN_PASSWORD={{ semaphore_admin_password | default('') | replace('$', '$$') }}
SEMAPHORE_ACCESS_KEY_ENCRYPTION={{ semaphore_access_key_encryption | default('') | replace('$', '$$') }}
ARCANE_ENCRYPTION_KEY={{ arcane_encryption_key | default('') | replace('$', '$$') }}
ARCANE_JWT_SECRET={{ arcane_jwt_secret | default('') | replace('$', '$$') }}
GRAFANA_ADMIN_PASSWORD={{ grafana_admin_password | default('') | replace('$', '$$') }}
SEMAPHORE_RUNNER_REG_TOKEN={{ semaphore_runner_reg_token | default('') | replace('$', '$$') }}
{# Infra-node stacks (technitium) — the same shared template renders on every compose
   host; the technitium compose guards with ${TECHNITIUM_ADMIN_PASSWORD:?}. An empty
   NAME_SERVERS falls back to the compose default (1.1.1.1, 9.9.9.9). #}
TECHNITIUM_ADMIN_PASSWORD={{ technitium_admin_password | default('') | replace('$', '$$') }}
NAME_SERVERS={{ technitium_forwarders | default('') }}
{# mullvad-exit stack (gluetun + tailscale sidecar). Secrets from SOPS; the reusable
   tailscale_authkey is reused for the container's exit-node identity. Location + the
   picker hostname are non-secret group_vars. Empty until the stack is enabled. #}
MULLVAD_WIREGUARD_PRIVATE_KEY={{ mullvad_wireguard_private_key | default('') | replace('$', '$$') }}
MULLVAD_WIREGUARD_ADDRESSES={{ mullvad_wireguard_addresses | default('') | replace('$', '$$') }}
MULLVAD_SERVER_CITIES={{ mullvad_server_cities | default('') }}
MULLVAD_SERVER_COUNTRIES={{ mullvad_server_countries | default('') }}
MULLVAD_EXIT_HOSTNAME={{ mullvad_exit_hostname | default('mullvad') }}
TAILSCALE_AUTHKEY={{ tailscale_authkey | default('') | replace('$', '$$') }}
