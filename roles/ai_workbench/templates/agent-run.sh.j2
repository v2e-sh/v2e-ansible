#!/usr/bin/env bash
# Run an AI agent headless (one-shot). Usage: agent-run <claude|codex> <prompt...>
# Sources the account's env-files (CLAUDE_CODE_OAUTH_TOKEN, Context7 key, ...) when
# present, right-sizes the claude --model via the model-router, then execs the tool
# full-power non-interactive. Installed by the ai-workbench role.
set -euo pipefail

tool="${1:-}"
shift || true
prompt="$*"

# Source the account's env-files (OAuth token, Context7, etc.) when present.
for env_file in \
  "$HOME/.config/agent-run/env" \
  "$HOME/.config/agent-brain/context7.env"; do
  if [ -f "$env_file" ]; then
    set -a
    . "$env_file"
    set +a
  fi
done
unset env_file

# model-router: right-sizes the --model flag for claude runs (hard floor for
# security/auth/network/architecture/plan work, else a cheap Haiku triage call).
# AGENT_RUN_MODEL_ROUTER=0 skips it; a missing/failing router never blocks the run.
router="/usr/local/lib/agent-run/model-router/router.py"
model_flag=()
if [ "$tool" = "claude" ] && [ "${AGENT_RUN_MODEL_ROUTER:-1}" != "0" ] && [ -x "$router" ]; then
  if decision="$("$router" route "$prompt" --retry "${AGENT_RUN_RETRY:-0}" 2>/dev/null)"; then
    model="$(python3 -c "import json,sys; print(json.loads(sys.argv[1])['model'])" "$decision" 2>/dev/null || true)"
    if [ -n "$model" ]; then
      reason="$(python3 -c "import json,sys; print(json.loads(sys.argv[1])['reason'])" "$decision" 2>/dev/null || true)"
      echo "agent-run: model-router -> $model ($reason)" >&2
      model_flag=(--model "$model")
    fi
  fi
fi

case "$tool" in
  claude) exec claude --dangerously-skip-permissions -p "$prompt" "${model_flag[@]}" ;;
  codex)  exec codex exec "$prompt" ;;
  *) echo "usage: agent-run <claude|codex> <prompt>" >&2; exit 2 ;;
esac
